    mainContent.innerHTML = '';
    window.scrollTo(0, 0);
    switch (pageName) {
        case 'home': renderHomePage(); break;
        case 'itinerary': renderItineraryPage(dayKey); break;
        case 'attractions': renderAttractionsPage(); break;
        case 'info': renderInfoPage(); break;
        case 'food': renderFoodGuidePage(); break;
